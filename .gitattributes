# Normalize line endings to LF for all text files.
* text=auto eol=lf

# Explicitly treat these as text with LF endings.
*.py    text eol=lf
*.tf    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.jsonl text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
Makefile text eol=lf
